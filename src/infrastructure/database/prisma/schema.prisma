generator client {
  provider = "prisma-client-js"
}

// prisma tự động đọc file .env dù cho chưa cài .dotenv, nhưng chỉ đọc được giá trị 
// trong env khi prisma đã start lên, những chỗ chưa start thì chịu
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") 
}

model Brand {
  id          String    @id @db.Uuid
  name        String    
  description String    @db.Text
  logo        String
  country     String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("brands")
}

model Category {
  id          String     @id @db.Uuid
  name        String
  description String     @db.Text
  parentId    String?    @map("parent_id") @db.Uuid
  attributes  Json?      // Lưu danh sách các thuộc tính của ngành hàng. ngành hàng cấp thấp nhất mới có
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@map("categories")
}

model Product {
  id                String                @id @db.Uuid
  name              String
  descriptions      String                @db.Text
  attributes        Json                  
  shopId            String                @map("shop_id") @db.Uuid
  categoryId        String                @map("category_id") @db.Uuid
  mainImage         String                @map("main_image") @db.Text
  galleryImage      Json                  @map("gallery_image")
  video             String?               @db.Text
  ratingAvg         Float                 @map("rating_avg")
  ratingCount       Int                   @map("rating_count")
  unit              String                @db.VarChar(30)
  isActive          Boolean               @map("is_active") @default(true) // trường này chỉ mang ý nghĩa có show sp ra cho người dùng ko
  approveStatus     ApproveProductStatus  @default(PENDING) @map("approve_status")
  rejectReason      String?               @map("reject_reason") @db.Text
  isDeleted         Boolean               @default(false) @map("is_deleted")
  deletedAt         DateTime?             @map("deleted_at")
  deletedBy         String?               @map("deleted_by") @db.Uuid
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  
  category          Category              @relation(fields: [categoryId], references: [id])
  variants          ProductVariant[]
  reviews           ProductReview[] 

  @@map("products")
}

enum ApproveProductStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// Nên có thêm trường name là name của product để hiển thị trong cart cho tiện
model ProductVariant {
  id          String   @id @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  sku         String   
  price       Int
  image       String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  
  product     Product  @relation(fields: [productId], references: [id])
  productVariantOptionValues ProductVariantOptionValue[]

  @@map("product_variants")
}

model ProductReview {
  id            String    @id @db.Uuid
  productId     String    @map("product_id") @db.Uuid
  shopId        String    @map("shop_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  orderId       String    @map("order_id") @db.Uuid
  buyerUsername String    @default("") @map("buyer_username") @db.VarChar(100)
  buyerAvatar   String?   @map("buyer_avatar") @db.Text
  productName   String    @default("") @map("product_name") @db.VarChar(255)
  productImage  String    @default("") @map("product_image") @db.Text
  sku           String    @db.VarChar(30)              // Xanh Blue
  rating        Int                                    // 1-5 sao
  content       String?   @db.Text                     // nullable vì có thể chỉ chấm sao
  images        Json?                                  // mảng URL, tối đa 3 ảnh
  video         String?   @db.Text                     // URL video, chỉ 1 cái
  isHidden      Boolean   @default(false) @map("is_hidden")  
  hiddenReason  String?   @map("hidden_reason") @db.Text
  hiddenAt      DateTime? @map("hidden_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  
  product       Product   @relation(fields: [productId], references: [id])
  reply         ReviewReply?
  reports       ReviewReport[]

  @@unique([orderId, productId])
  @@map("product_reviews")
}

model ReviewReply {
  id          String   @id @db.Uuid
  reviewId    String   @unique @map("review_id") @db.Uuid
  shopId      String   @map("shop_id") @db.Uuid
  content     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  review      ProductReview @relation(fields: [reviewId], references: [id])

  @@map("review_replies")
}

model ReviewReport {
  id          String             @id @db.Uuid
  reviewId    String             @map("review_id") @db.Uuid
  reporterId  String             @map("reporter_id") @db.Uuid
  reporterUsername String        @default("") @map("reporter_username") @db.VarChar(100)
  reporterAvatar   String?       @map("reporter_avatar") @db.Text
  reason      ReviewReportReason
  description String?            @db.Text
  status      ReviewReportStatus @default(PENDING)
  createdAt   DateTime           @default(now()) @map("created_at")

  review      ProductReview      @relation(fields: [reviewId], references: [id])

  @@unique([reviewId, reporterId])
  @@map("review_reports")
}

enum ReviewReportReason {
  VULGAR
  ADULT_CONTENT
  SPAM
  PERSONAL_INFO
  ILLEGAL_ADVERTISING
  FALSE_INFORMATION
  OTHER
}

enum ReviewReportStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Option {
  id          String   @id @db.Uuid
  name        String   @db.VarChar(30)

  optionValues OptionValue[]

  @@map("options")
}

model OptionValue {
  id          String   @id @db.Uuid
  value       String   @db.VarChar(30)
  optionId    String   @map("option_id") @db.Uuid

  option      Option   @relation(fields: [optionId], references: [id])
  productVariantOptionValues ProductVariantOptionValue[]
  
  @@map("option_values")
}

model ProductVariantOptionValue {
  variantId     String   @map("variant_id") @db.Uuid
  optionValueId String   @map("option_value_id") @db.Uuid

  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)  // N-1
  optionValue   OptionValue    @relation(fields: [optionValueId], references: [id])  // N-1

  @@id([variantId, optionValueId])
  @@map("product_variant_option_values")
}
